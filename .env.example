# Root Environment Variables for Docker Compose
# Copy this file to .env in the root directory

# Database Password (used by PostgreSQL container)
DB_PASSWORD=benocode_dev_password

# JWT Secret (min 32 characters)
JWT_SECRET=dev-jwt-secret-min-32-characters-long-change-in-production

# CSRF Secret (must be different from JWT_SECRET, min 32 characters)
CSRF_SECRET=dev-csrf-secret-min-32-characters-long-change-in-production

# Redis Password (for production Redis auth)
REDIS_PASSWORD=dev-redis-password-change-in-production

# Brevo Email Service
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@benocode.sk

# Application Configuration
ADMIN_EMAIL=admin@benocode.sk

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
